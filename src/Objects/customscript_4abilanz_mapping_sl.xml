<suitelet scriptid="customscript_4abilanz_mapping_sl">
  <description>Bilanz HGB — Konten-Mapping-View: read-only, zeigt fuer jedes BS-Konto die zugewiesene Bilanz-Zeile.</description>
  <isinactive>F</isinactive>
  <name>4a Bilanz HGB — Konten-Mapping</name>
  <notifyadmins>F</notifyadmins>
  <notifyowner>T</notifyowner>
  <scriptfile>[/SuiteScripts/4abilanz/4a_bilanz_mapping_sl.js]</scriptfile>
  <scriptdeployments>
    <scriptdeployment scriptid="customdeploy_4abilanz_mapping_sl">
      <allemployees>F</allemployees>
      <allpartners>F</allpartners>
      <allroles>T</allroles>
      <audslctrole></audslctrole>
      <isdeployed>T</isdeployed>
      <loglevel>DEBUG</loglevel>
      <runasrole></runasrole>
      <status>RELEASED</status>
      <title>4a Bilanz HGB — Konten-Mapping</title>
      <custscript_4abilanz_map_chart>skr03</custscript_4abilanz_map_chart>
    </scriptdeployment>
  </scriptdeployments>
  <scriptcustomfields>
    <scriptcustomfield scriptid="custscript_4abilanz_map_chart">
      <accesslevel>2</accesslevel>
      <applyformatting>F</applyformatting>
      <checkspelling>F</checkspelling>
      <defaultchecked>F</defaultchecked>
      <defaultvalue>skr03</defaultvalue>
      <description>Kontenrahmen-Mapping: skr03 | skr04 | nstype.</description>
      <displaytype>NORMAL</displaytype>
      <fieldtype>TEXT</fieldtype>
      <isformula>F</isformula>
      <ismandatory>F</ismandatory>
      <label>Kontenrahmen</label>
      <storevalue>T</storevalue>
    </scriptcustomfield>
  </scriptcustomfields>
</suitelet>
