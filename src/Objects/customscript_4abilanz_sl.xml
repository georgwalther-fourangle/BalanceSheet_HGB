<suitelet scriptid="customscript_4abilanz_sl">
  <description>Bilanz nach §266 HGB (Kapitalgesellschaft) — SKR03/SKR04 oder NetSuite-Kontotyp.</description>
  <isinactive>F</isinactive>
  <name>4a Bilanz HGB</name>
  <notifyadmins>F</notifyadmins>
  <notifyowner>T</notifyowner>
  <scriptfile>[/SuiteScripts/4abilanz/4a_bilanz_sl.js]</scriptfile>
  <scriptdeployments>
    <scriptdeployment scriptid="customdeploy_4abilanz_sl">
      <allemployees>F</allemployees>
      <allpartners>F</allpartners>
      <allroles>T</allroles>
      <audslctrole></audslctrole>
      <isdeployed>T</isdeployed>
      <loglevel>DEBUG</loglevel>
      <runasrole></runasrole>
      <status>RELEASED</status>
      <title>4a Bilanz HGB</title>
      <custscript_4abilanz_chartofaccounts>skr03</custscript_4abilanz_chartofaccounts>
      <custscript_4abilanz_chartlayout>lean</custscript_4abilanz_chartlayout>
    </scriptdeployment>
  </scriptdeployments>
  <scriptcustomfields>
    <scriptcustomfield scriptid="custscript_4abilanz_chartofaccounts">
      <accesslevel>2</accesslevel>
      <applyformatting>F</applyformatting>
      <checkspelling>F</checkspelling>
      <defaultchecked>F</defaultchecked>
      <defaultvalue>skr04</defaultvalue>
      <description>Kontenrahmen-Mapping: skr03 | skr04 | nstype (NetSuite-Kontotyp-Fallback).</description>
      <displaytype>NORMAL</displaytype>
      <fieldtype>TEXT</fieldtype>
      <isformula>F</isformula>
      <ismandatory>F</ismandatory>
      <label>Kontenrahmen</label>
      <storevalue>T</storevalue>
    </scriptcustomfield>
    <scriptcustomfield scriptid="custscript_4abilanz_chartlayout">
      <accesslevel>2</accesslevel>
      <applyformatting>F</applyformatting>
      <checkspelling>F</checkspelling>
      <defaultchecked>F</defaultchecked>
      <defaultvalue>lean</defaultvalue>
      <description>Bilanz-Struktur-Variante: voll (§266 vollständig) | lean (schlanke GRITSpot-aehnliche Struktur).</description>
      <displaytype>NORMAL</displaytype>
      <fieldtype>TEXT</fieldtype>
      <isformula>F</isformula>
      <ismandatory>F</ismandatory>
      <label>Bilanz-Struktur</label>
      <storevalue>T</storevalue>
    </scriptcustomfield>
  </scriptcustomfields>
</suitelet>
